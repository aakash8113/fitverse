// Prisma schema for Fitverse Ecommerce
// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

enum UserRole {
  USER
  ADMIN
}

enum CarouselPlacement {
  HOME
  SHOP
}

enum AiModelStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum AiModelGender {
  MALE
  FEMALE
  OTHER
}

enum AiCreditPurchaseStatus {
  PENDING
  COMPLETED
  FAILED
}

model CarouselSlide {
  id         String            @id @default(uuid())
  placement  CarouselPlacement
  imageUrl   String
  altText    String?
  sortOrder  Int
  isActive   Boolean           @default(true)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@unique([placement, sortOrder])
  @@index([placement, isActive])
  @@map("carousel_slides")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?  @unique
  password  String   // Hashed with bcrypt
  role      UserRole @default(USER)
  
  // Email/Phone Verification
  isEmailVerified Boolean  @default(false)
  isPhoneVerified Boolean  @default(false)
  emailOTP        String?
  phoneOTP        String?
  otpExpiresAt    DateTime?
  
  // Fitverse Coins
  coinBalance     Int              @default(0)

  // Fitverse AI credits
  aiCredits        Int              @default(5)
  aiTryOnCount     Int              @default(0)

  // Relations
  cart            Cart?
  orders          Order[]
  addresses       Address[]
  thriftListings  ThriftListing[]
  thriftItems     ThriftItem[]
  returnRequests  ReturnRequest[]
  coinTransactions CoinTransaction[]
  reviews         Review[]
  helpfulReviews  ReviewHelpful[]
  couponUsages       CouponUsage[]
  blockedFromCoupons CouponBlockedUser[]
  aiModels        AiModel[]
  aiUsage         AiUsage[]
  aiCreditPurchases AiCreditPurchase[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([phone])
  @@map("users")
}

model AiModel {
  id               String        @id @default(uuid())
  userId           String
  name             String
  gender           AiModelGender
  imageUrl         String
  status           AiModelStatus @default(PENDING)
  goodClothesTypes String[]      @default([])
  note             String?
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("ai_models")
}

model AiUsage {
  id        String   @id @default(uuid())
  userId    String
  taskId    String   @unique
  hdMode    Boolean  @default(false)
  success   Boolean?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([success])
  @@map("ai_usage")
}

model AiCreditPurchase {
  id            String                 @id @default(uuid())
  userId        String
  credits       Int
  amountInPaise Int
  status        AiCreditPurchaseStatus @default(PENDING)
  phonePeOrderId String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("ai_credit_purchases")
}

// ============================================
// ADDRESS
// ============================================

model Address {
  id           String  @id @default(uuid())
  userId       String
  name         String
  phone        String
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  zipCode      String
  country      String  @default("United States")
  isDefault    Boolean @default(false)
  
  // Relations
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]
  thriftListings ThriftListing[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("addresses")
}

// ============================================
// PRODUCT — category system
// ============================================

enum Gender {
  MENS
  WOMENS
}

enum WearType {
  TOPWEAR
  BOTTOMWEAR
}

// 4 Topwear + 4 Bottomwear categories
enum ClothingCategory {
  TSHIRT
  SHIRT
  HOODIE
  JACKET
  JEANS
  TROUSER
  TRACKPANT
  CARGO
}

// Sub-categories (nullable — only some categories have subs)
enum ClothingSubCategory {
  // T-Shirt subs
  OVERSIZED
  POLO
  DROP_SHOULDER
  V_NECK
  SHORT_SLEEVED
  LONG_SLEEVED
  // Shirt subs
  PRINTED
  PLAIN
  TEXTURED
  // Jeans subs
  DENIM
  SKINNY
  BAGGY
  BOOT_CUT
}

model Product {
  id          String               @id @default(uuid())
  name        String
  description String               @db.Text
  price       Decimal              @db.Decimal(10, 2)
  brand       String?

  // Category hierarchy
  gender      Gender
  wearType    WearType
  category    ClothingCategory
  subCategory ClothingSubCategory?

  // Sizes available (TOPWEAR: XS/S/M/L/XL/XXL/3XL  |  BOTTOMWEAR: 28/30/32/34/36/38/40/42)
  availableSizes String[]          @default([])

  // true = this product was a thrift item (listed by admin)
  isThrift       Boolean              @default(false)

  // Admin-assessed condition for thrift products (POOR/FAIR/GOOD/VERY_GOOD/LIKE_NEW)
  thriftCondition String?

  // Images
  images      String[]             @default([])

  // Per-size stock: e.g. {"S":4,"M":10,"XL":3}
  sizeStock   Json                 @default("{}")

  // Soft delete
  isActive    Boolean              @default(true)

  // Relations
  cartItems      CartItem[]
  orderItems     OrderItem[]
  reviews        Review[]
  couponProducts CouponProduct[]
  thriftSourceItem ThriftItem? @relation("ListedThriftProduct")

  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([gender])
  @@index([wearType])
  @@index([category])
  @@index([isThrift])
  @@index([isActive])
  @@map("products")
}

// ============================================
// CART
// ============================================

model Cart {
  id     String     @id @default(uuid())
  userId String     @unique
  
  // Relations
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("carts")
}

model CartItem {
  id        String @id @default(uuid())
  cartId    String
  productId String
  quantity  Int    @default(1)
  size      String @default("")
  
  // Relations
  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId, size])
  @@index([cartId])
  @@index([productId])
  @@map("cart_items")
}

// ============================================
// ORDER
// ============================================

enum OrderStatus {
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CARD
  COD
  WALLET
  COINS
}

model Order {
  id            String        @id @default(uuid())
  orderNumber   String        @unique // e.g., "FV20260228001"
  userId        String
  addressId     String?
  
  // Payment
  paymentMethod PaymentMethod
  paymentStatus String        @default("PENDING") // PENDING, COMPLETED, FAILED
  paymentId     String?       // Transaction ID from payment gateway
  
  // Pricing (stored at order time, not recalculated)
  subtotal      Decimal       @db.Decimal(10, 2)
  shipping      Decimal       @db.Decimal(10, 2)
  tax           Decimal       @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  coinsUsed     Int           @default(0)
  
  // Status
  status        OrderStatus   @default(PROCESSING)
  
  // Coupon
  couponId       String?
  couponCode     String?   // snapshot of code at order time
  couponDiscount Decimal   @default(0) @db.Decimal(10, 2)

  // Relations
  user       User        @relation(fields: [userId], references: [id])
  address    Address?    @relation(fields: [addressId], references: [id], onDelete: SetNull)
  orderItems OrderItem[]
  returnRequests ReturnRequest[]
  coupon     Coupon?     @relation(fields: [couponId], references: [id], onDelete: SetNull)

  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deliveredAt   DateTime?
  cancelledAt   DateTime?

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String?
  
  // Snapshot of product at order time
  productName  String
  productImage String
  price        Decimal @db.Decimal(10, 2)
  quantity     Int
  size         String  @default("")
  
  // Relations
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  returnItems ReturnRequestItem[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// ============================================
// THRIFT MARKETPLACE
// ============================================

enum ThriftListingStatus {
  PENDING           // Awaiting admin review
  OFFER_SENT        // Admin sent price offer, awaiting user response
  APPROVED          // User accepted offer, pickup confirmed
  REJECTED          // Admin rejected OR user declined offer
  PICKED_UP         // Items physically received
  COMPLETED         // All items listed/sold
}

enum ThriftItemStatus {
  PENDING               // Awaiting admin review
  APPROVED              // Admin approved with estimated value
  REJECTED              // Admin rejected this item
  PICKED_UP             // Item physically received
  UNDER_REFURBISHMENT   // Being cleaned/repaired
  REFURBISHMENT_COMPLETE // Refurb done, ready to move to store
  LISTED                // Live in store as Product
  SOLD                  // Sold to a buyer
}

enum ThriftItemCondition {
  POOR
  FAIR
  GOOD
  VERY_GOOD
  LIKE_NEW
}

// ============================================
// RETURNS & REPLACEMENTS
// ============================================

model ReturnRequest {
  id          String   @id @default(uuid())
  requestNumber String @unique // e.g. "RET20260303001"
  orderId     String
  userId      String

  type        String   // "RETURN" | "REPLACEMENT"
  status      String   @default("REQUESTED")
  // REQUESTED → APPROVED / REJECTED
  // APPROVED  → ITEM_RECEIVED → REFUND_INITIATED / REPLACEMENT_SHIPPED → COMPLETED

  reason      String   // "DAMAGED" | "WRONG_ITEM" | "SIZE_ISSUE" | "QUALITY_ISSUE" | "OTHER"
  description String?  @db.Text
  images      String[] @default([])

  // For REPLACEMENT — requested new size
  replacementSize String?

  // For RETURN of COD order — bank / UPI details
  bankAccountName String?
  bankAccountNumber String?
  bankIFSC        String?
  upiHandle       String?

  // Admin fields
  adminNote   String?  @db.Text
  resolvedAt  DateTime?

  // Relations
  order       Order          @relation(fields: [orderId], references: [id])
  user        User           @relation(fields: [userId], references: [id])
  items       ReturnRequestItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@map("return_requests")
}

model ReturnRequestItem {
  id              String @id @default(uuid())
  returnRequestId String
  orderItemId     String
  quantity        Int    @default(1)

  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  orderItem       OrderItem     @relation(fields: [orderItemId], references: [id])

  @@index([returnRequestId])
  @@map("return_request_items")
}

model ThriftListing {
  id         String              @id @default(uuid())
  userId     String

  status     ThriftListingStatus @default(PENDING)

  // Pickup address (provided by user on submission)
  pickupAddressId String?

  // Pickup schedule (set by admin when approving)
  pickupDate DateTime?
  pickupSlot String?             // e.g. "9 AM – 12 PM"

  // Admin communication
  adminNotes String?             @db.Text

  // Offer negotiation
  contactRequested Boolean       @default(false) // true when user clicks "Call Us"

  // Relations
  user          User          @relation(fields: [userId], references: [id])
  pickupAddress Address?      @relation(fields: [pickupAddressId], references: [id])
  items         ThriftItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("thrift_listings")
}

model ThriftItem {
  id        String @id @default(uuid())
  listingId String
  userId    String

  // Item details (filled by user)
  name        String
  brand       String?
  gender      Gender
  wearType    WearType
  category    ClothingCategory
  subCategory ClothingSubCategory?
  size        String?
  condition   ThriftItemCondition
  description String              @db.Text
  images      String[]            @default([])

  // Pricing
  originalPrice      Decimal? @db.Decimal(10, 2)  // What user paid originally
  estimatedValue     Decimal? @db.Decimal(10, 2)  // Admin's offer to user
  refurbishmentCost  Decimal? @db.Decimal(10, 2)  // Cost to clean/repair
  listedPrice        Decimal? @db.Decimal(10, 2)  // Final store price

  // Status tracking
  status          ThriftItemStatus @default(PENDING)
  rejectionReason String?          @db.Text
  adminNotes      String?          @db.Text

  // When the item is listed as a Product in the store
  listedProductId String? @unique

  // Relations
  listing ThriftListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id])
  listedProduct Product? @relation("ListedThriftProduct", fields: [listedProductId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([listingId])
  @@index([userId])
  @@index([status])
  @@map("thrift_items")
}

// ============================================
// FITVERSE COINS
// ============================================

model CoinTransaction {
  id          String   @id @default(uuid())
  userId      String
  amount      Int      // positive = credit, negative = debit
  type        String   // THRIFT_REWARD | ORDER_PAYMENT | ADMIN_ADJUSTMENT
  description String
  referenceId String?  // listingId or orderId

  // Relations
  user        User     @relation(fields: [userId], references: [id])

  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("coin_transactions")
}

// ============================================
// PRODUCT REVIEWS
// ============================================

model Review {
  id        String   @id @default(uuid())
  productId String
  userId    String
  rating    Int      // 1-5
  title     String?
  comment   String   @db.Text
  images    String[] @default([])

  // Relations
  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  helpfulBy ReviewHelpful[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, userId]) // one review per user per product
  @@index([productId])
  @@index([userId])
  @@map("reviews")
}

model ReviewHelpful {
  id       String @id @default(uuid())
  reviewId String
  userId   String

  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
  @@map("review_helpful")
}

// ============================================
// COUPONS
// ============================================

enum CouponDiscountType {
  PERCENTAGE
  FLAT
}

enum CouponScope {
  ALL
  CATEGORY
  PRODUCT
}

enum CouponTarget {
  SHOP
  THRIFT
  BOTH
}

model Coupon {
  id          String             @id @default(uuid())
  code        String             @unique // Always stored uppercase
  description String?            @db.Text

  discountType      CouponDiscountType
  discountValue     Decimal    @db.Decimal(10, 2)
  maxDiscountAmount Decimal?   @db.Decimal(10, 2) // Cap for PERCENTAGE type
  minOrderAmount    Decimal?   @db.Decimal(10, 2) // Minimum cart subtotal to apply

  totalUsageLimit   Int?       // null = unlimited
  perUserLimit      Int        @default(1)
  isFirstOrderOnly  Boolean    @default(false)

  applicableTo      CouponTarget @default(SHOP) // SHOP | THRIFT | BOTH
  scope             CouponScope  @default(ALL)  // ALL | CATEGORY | PRODUCT

  // For CATEGORY scope — store enum string values
  applicableGenders    String[] @default([])
  applicableWearTypes  String[] @default([])
  applicableCategories String[] @default([])

  isActive  Boolean   @default(true)
  startsAt  DateTime?
  expiresAt DateTime?

  usageCount Int @default(0)

  // Relations
  products     CouponProduct[]
  usages       CouponUsage[]
  blockedUsers CouponBlockedUser[]
  orders       Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([isActive])
  @@map("coupons")
}

model CouponProduct {
  id        String @id @default(uuid())
  couponId  String
  productId String

  coupon  Coupon  @relation(fields: [couponId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([couponId, productId])
  @@index([couponId])
  @@map("coupon_products")
}

model CouponUsage {
  id       String @id @default(uuid())
  couponId String
  userId   String
  orderId  String @unique

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([couponId])
  @@index([userId])
  @@map("coupon_usages")
}

model CouponBlockedUser {
  id       String @id @default(uuid())
  couponId String
  userId   String

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([couponId, userId])
  @@index([couponId])
  @@map("coupon_blocked_users")
}
