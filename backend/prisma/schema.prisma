// Prisma schema for Fitverse Ecommerce
// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

enum UserRole {
  USER
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?  @unique
  password  String   // Hashed with bcrypt
  role      UserRole @default(USER)
  
  // Email/Phone Verification
  isEmailVerified Boolean  @default(false)
  isPhoneVerified Boolean  @default(false)
  emailOTP        String?
  phoneOTP        String?
  otpExpiresAt    DateTime?
  
  // Relations
  cart            Cart?
  orders          Order[]
  addresses       Address[]
  thriftListings  ThriftListing[]
  thriftItems     ThriftItem[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([phone])
  @@map("users")
}

// ============================================
// ADDRESS
// ============================================

model Address {
  id           String  @id @default(uuid())
  userId       String
  name         String
  phone        String
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  zipCode      String
  country      String  @default("United States")
  isDefault    Boolean @default(false)
  
  // Relations
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]
  thriftListings ThriftListing[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("addresses")
}

// ============================================
// PRODUCT — category system
// ============================================

enum Gender {
  MENS
  WOMENS
}

enum WearType {
  TOPWEAR
  BOTTOMWEAR
}

// 4 Topwear + 4 Bottomwear categories
enum ClothingCategory {
  TSHIRT
  SHIRT
  HOODIE
  JACKET
  JEANS
  TROUSER
  TRACKPANT
  CARGO
}

// Sub-categories (nullable — only some categories have subs)
enum ClothingSubCategory {
  // T-Shirt subs
  OVERSIZED
  POLO
  DROP_SHOULDER
  V_NECK
  SHORT_SLEEVED
  LONG_SLEEVED
  // Shirt subs
  PRINTED
  PLAIN
  TEXTURED
  // Jeans subs
  DENIM
  SKINNY
  BAGGY
  BOOT_CUT
}

model Product {
  id          String               @id @default(uuid())
  name        String
  description String               @db.Text
  price       Decimal              @db.Decimal(10, 2)
  stock       Int                  @default(0)
  brand       String?

  // Category hierarchy
  gender      Gender
  wearType    WearType
  category    ClothingCategory
  subCategory ClothingSubCategory?

  // Sizes available (TOPWEAR: XS/S/M/L/XL/XXL/3XL  |  BOTTOMWEAR: 28/30/32/34/36/38/40/42)
  availableSizes String[]          @default([])

  // true = this product was a thrift item (listed by admin)
  isThrift    Boolean              @default(false)

  // Images
  images      String[]             @default([])

  // Soft delete
  isActive    Boolean              @default(true)

  // Relations
  cartItems   CartItem[]
  orderItems  OrderItem[]

  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([gender])
  @@index([wearType])
  @@index([category])
  @@index([isThrift])
  @@index([isActive])
  @@map("products")
}

// ============================================
// CART
// ============================================

model Cart {
  id     String     @id @default(uuid())
  userId String     @unique
  
  // Relations
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("carts")
}

model CartItem {
  id        String @id @default(uuid())
  cartId    String
  productId String
  quantity  Int    @default(1)
  size      String @default("")
  
  // Relations
  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId, size])
  @@index([cartId])
  @@index([productId])
  @@map("cart_items")
}

// ============================================
// ORDER
// ============================================

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CARD
  COD
  WALLET
}

model Order {
  id            String        @id @default(uuid())
  orderNumber   String        @unique // e.g., "FV20260228001"
  userId        String
  addressId     String?
  
  // Payment
  paymentMethod PaymentMethod
  paymentStatus String        @default("PENDING") // PENDING, COMPLETED, FAILED
  paymentId     String?       // Transaction ID from payment gateway
  
  // Pricing (stored at order time, not recalculated)
  subtotal      Decimal       @db.Decimal(10, 2)
  shipping      Decimal       @db.Decimal(10, 2)
  tax           Decimal       @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  
  // Status
  status        OrderStatus   @default(PENDING)
  
  // Relations
  user       User        @relation(fields: [userId], references: [id])
  address    Address?    @relation(fields: [addressId], references: [id], onDelete: SetNull)
  orderItems OrderItem[]
  
  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deliveredAt   DateTime?
  cancelledAt   DateTime?

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  
  // Snapshot of product at order time
  productName  String
  productImage String
  price        Decimal @db.Decimal(10, 2)
  quantity     Int
  
  // Relations
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// ============================================
// THRIFT MARKETPLACE
// ============================================

enum ThriftListingStatus {
  PENDING           // Awaiting admin review
  APPROVED          // Admin accepted, pickup scheduled
  REJECTED          // Admin rejected all items
  PICKED_UP         // Items physically received
  COMPLETED         // All items listed/sold
}

enum ThriftItemStatus {
  PENDING               // Awaiting admin review
  APPROVED              // Admin approved with estimated value
  REJECTED              // Admin rejected this item
  PICKED_UP             // Item physically received
  UNDER_REFURBISHMENT   // Being cleaned/repaired
  REFURBISHMENT_COMPLETE // Refurb done, ready to move to store
  LISTED                // Live in store as Product
  SOLD                  // Sold to a buyer
}

enum ThriftItemCondition {
  POOR
  FAIR
  GOOD
  VERY_GOOD
  LIKE_NEW
}

model ThriftListing {
  id         String              @id @default(uuid())
  userId     String

  status     ThriftListingStatus @default(PENDING)

  // Pickup address (provided by user on submission)
  pickupAddressId String?

  // Pickup schedule (set by admin when approving)
  pickupDate DateTime?
  pickupSlot String?             // e.g. "9 AM – 12 PM"

  // Admin communication
  adminNotes String?             @db.Text

  // Relations
  user          User          @relation(fields: [userId], references: [id])
  pickupAddress Address?      @relation(fields: [pickupAddressId], references: [id])
  items         ThriftItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("thrift_listings")
}

model ThriftItem {
  id        String @id @default(uuid())
  listingId String
  userId    String

  // Item details (filled by user)
  name        String
  brand       String?
  gender      Gender
  wearType    WearType
  category    ClothingCategory
  subCategory ClothingSubCategory?
  size        String?
  condition   ThriftItemCondition
  description String              @db.Text
  images      String[]            @default([])

  // Pricing
  originalPrice      Decimal? @db.Decimal(10, 2)  // What user paid originally
  estimatedValue     Decimal? @db.Decimal(10, 2)  // Admin's offer to user
  refurbishmentCost  Decimal? @db.Decimal(10, 2)  // Cost to clean/repair
  listedPrice        Decimal? @db.Decimal(10, 2)  // Final store price

  // Status tracking
  status          ThriftItemStatus @default(PENDING)
  rejectionReason String?          @db.Text
  adminNotes      String?          @db.Text

  // When the item is listed as a Product in the store
  listedProductId String? @unique

  // Relations
  listing ThriftListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([listingId])
  @@index([userId])
  @@index([status])
  @@map("thrift_items")
}
